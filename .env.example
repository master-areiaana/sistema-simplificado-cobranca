# ==== Supabase (banco de dados do sistema) ====
# Pegue estes 2 valores no painel do Supabase:
#   Project Settings -> API -> Project URL  e  Project API keys (anon public)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ==== Base path do deploy (opcional) ====
# GitHub Pages de projeto: "/nome-do-repo/"  (ex.: /sistema-simplificado-cobranca/)
# Domínio próprio / Vercel / Netlify: deixe "/" ou não defina.
# VITE_BASE_PATH=/sistema-simplificado-cobranca/
